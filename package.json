{
  "name": "shieldguard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @shieldguard/dashboard",
    "build": "npm run build -w @shieldguard/dashboard",
    "preview": "npm run preview -w @shieldguard/dashboard",
    "lint": "npm run lint -w @shieldguard/dashboard",
    "clean": "node scripts/rm-dist.mjs",
    "sdk:build": "npm run build -w @shieldguard/sdk",
    "simulate-fraud": "tsx scripts/simulate-fraud.ts",
    "turbo:build": "turbo run build",
    "turbo:lint": "turbo run lint"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "turbo": "^2.3.3"
  },
  "engines": {
    "node": ">=20"
  }
}
